{
  "manifest_version": 3,
  "name": "Crunchyroll PiP Helper",
  "description": "Forces Picture-in-Picture for Crunchyroll videos via button or keyboard shortcut. By @mlemors: github.com/mlemors/crunchyroll-pip-extension",
  "version": "1.0.0",
  "homepage_url": "https://github.com/mlemors/crunchyroll-pip-extension",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://www.crunchyroll.com/*",
    "https://crunchyroll.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "toggle-pip": {
      "suggested_key": {
        "default": "Alt+Shift+P"
      },
      "description": "Start Picture-in-Picture for the active Crunchyroll video"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.crunchyroll.com/*",
        "https://crunchyroll.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Crunchyroll PiP"
  }
}
